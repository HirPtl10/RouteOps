generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  FLEET_MANAGER
  DISPATCHER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}

model Organization {
  id        String    @id @default(cuid())
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  users          User[]
  vehicles       Vehicle[]
  drivers        Driver[]
  trips          Trip[]
  maintenanceLogs MaintenanceLog[]
  fuelLogs        FuelLog[]
  expenses        Expense[]

  @@index([name])
}

model User {
  id             String       @id @default(cuid())
  organizationId String
  email          String       @unique
  passwordHash   String?
  name           String?
  role           Role
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, role])
}

model Vehicle {
  id             String         @id @default(cuid())
  organizationId String
  code           String
  vin            String?        @unique
  plateNumber    String?        @unique
  make           String?
  model          String?
  year           Int?
  capacityKg     Int?
  status         VehicleStatus  @default(AVAILABLE)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  trips           Trip[]
  maintenanceLogs MaintenanceLog[]
  fuelLogs        FuelLog[]
  expenses        Expense[]

  @@unique([organizationId, code])
  @@index([organizationId, status])
}

model Driver {
  id                String       @id @default(cuid())
  organizationId    String
  firstName         String
  lastName          String
  licenseNumber     String
  licenseExpiresAt  DateTime?
  phone             String?
  status            DriverStatus @default(AVAILABLE)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  trips        Trip[]

  @@unique([organizationId, licenseNumber])
  @@index([organizationId, status])
}

model Trip {
  id             String      @id @default(cuid())
  organizationId String
  vehicleId      String?
  driverId       String?
  tripNumber     String
  status         TripStatus  @default(DRAFT)
  cargoWeightKg  Int?
  notes          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vehicle      Vehicle?     @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  driver       Driver?      @relation(fields: [driverId], references: [id], onDelete: SetNull)
  expenses     Expense[]
  fuelLogs     FuelLog[]

  @@unique([organizationId, tripNumber])
  @@index([organizationId, status])
  @@index([vehicleId])
  @@index([driverId])
}

model MaintenanceLog {
  id             String   @id @default(cuid())
  organizationId String
  vehicleId      String
  openedAt       DateTime @default(now())
  closedAt       DateTime?
  description    String
  cost           Decimal? @db.Decimal(12, 2)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vehicle      Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  expenses     Expense[]

  @@index([organizationId, vehicleId])
  @@index([vehicleId, closedAt])
}

model FuelLog {
  id             String   @id @default(cuid())
  organizationId String
  vehicleId      String
  tripId         String?
  fueledAt       DateTime @default(now())
  liters         Decimal  @db.Decimal(10, 2)
  totalCost      Decimal  @db.Decimal(12, 2)
  odometerKm     Int?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vehicle      Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  trip         Trip?        @relation(fields: [tripId], references: [id], onDelete: SetNull)
  expenses     Expense[]

  @@index([organizationId, vehicleId])
  @@index([vehicleId, fueledAt])
  @@index([tripId])
}

model Expense {
  id                String    @id @default(cuid())
  organizationId    String
  tripId            String?
  vehicleId         String?
  maintenanceLogId   String?
  fuelLogId          String?
  description        String
  amount             Decimal   @db.Decimal(12, 2)
  incurredAt         DateTime  @default(now())
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  trip            Trip?           @relation(fields: [tripId], references: [id], onDelete: SetNull)
  vehicle         Vehicle?        @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  maintenanceLog  MaintenanceLog? @relation(fields: [maintenanceLogId], references: [id], onDelete: SetNull)
  fuelLog         FuelLog?        @relation(fields: [fuelLogId], references: [id], onDelete: SetNull)

  @@index([organizationId, incurredAt])
  @@index([tripId])
  @@index([vehicleId])
  @@index([maintenanceLogId])
  @@index([fuelLogId])
}
